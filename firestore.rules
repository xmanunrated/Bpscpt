rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'user', 'admin', 'content_manager', 'support_staff')
    //   - isPremium: bool (required)
    //   - createdAt: timestamp (required)
    //   - premiumSince: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "ankitrgpv@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isContentManager() {
      return isAuthenticated() && 
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'content_manager'));
    }

    function isSupportStaff() {
      return isAuthenticated() && 
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'support_staff'));
    }

    function isValidCurrentAffairs(data) {
      return data.keys().hasAll(['date', 'content', 'type', 'createdAt']) &&
             data.date is string &&
             data.content is string &&
             data.type in ['daily', 'weekly', 'fortnightly'] &&
             data.createdAt is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'isPremium', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin', 'content_manager', 'support_staff'] &&
             data.isPremium is bool &&
             data.createdAt is string;
    }

    function isValidHomepageConfig(data) {
      return data.keys().hasAll(['heroTitle', 'heroSubtitle', 'features']) &&
             data.heroTitle is string &&
             data.heroSubtitle is string &&
             data.features is list;
    }

    function isValidSEOConfig(data) {
      return data.keys().hasAll(['title', 'description']) &&
             data.title is string &&
             data.description is string;
    }

    function isValidExamSchedule(data) {
      return data.keys().hasAll(['title', 'date', 'type', 'createdAt']) &&
             data.title is string &&
             data.date is string &&
             data.type in ['exam', 'deadline', 'result'] &&
             data.createdAt is string;
    }

    function isValidCACache(data) {
      return data.keys().hasAll(['data', 'timestamp']) &&
             data.data is map &&
             data.timestamp is string;
    }

    function isValidRound(data) {
      return data.keys().hasAll(['sourceYear', 'predictions', 'model', 'createdAt', 'uid']) &&
             data.sourceYear is int &&
             data.predictions is map &&
             data.model is string &&
             data.createdAt is int &&
             data.uid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isSupportStaff();
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      (
                        (request.resource.data.role == 'user' && request.resource.data.isPremium == false) ||
                        (request.auth.token.email == "ankitrgpv@gmail.com" && request.auth.token.email_verified == true)
                      );
      allow update: if isAdmin() || 
                      (isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       request.resource.data.role == resource.data.role && 
                       request.resource.data.isPremium == resource.data.isPremium);
      allow delete: if isAdmin();
    }

    match /current_affairs/{caId} {
      allow read: if isAuthenticated();
      allow write: if isContentManager() && isValidCurrentAffairs(request.resource.data);
    }

    match /exam_schedule/{scheduleId} {
      allow read: if true;
      allow write: if isContentManager() && isValidExamSchedule(request.resource.data);
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isContentManager();
    }

    match /llms/{modelId} {
      allow read: if true;
      allow write: if isContentManager();
    }

    match /pricing/{planId} {
      allow read: if true;
      allow write: if isContentManager();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isContentManager();
    }

    match /ca_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidCACache(request.resource.data);
    }

    match /rounds/{roundId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidRound(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin()) && isValidRound(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
