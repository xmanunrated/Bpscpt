rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'user' or 'admin')
    //   - isPremium: bool (required)
    //   - createdAt: timestamp (required)
    //   - premiumSince: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ankitrgpv@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidCurrentAffairs(data) {
      return data.keys().hasAll(['date', 'content', 'type', 'createdAt']) &&
             data.date is string &&
             data.content is string &&
             data.type in ['daily', 'weekly', 'fortnightly'] &&
             data.createdAt is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'isPremium']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.isPremium is bool;
    }

    function isValidHomepageConfig(data) {
      return data.keys().hasAll(['heroTitle', 'heroSubtitle', 'features']) &&
             data.heroTitle is string &&
             data.heroSubtitle is string &&
             data.features is list;
    }

    function isValidSEOConfig(data) {
      return data.keys().hasAll(['title', 'description']) &&
             data.title is string &&
             data.description is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.role == 'user' && 
                      request.resource.data.isPremium == false;
      allow update: if isAdmin() || 
                      (isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       request.resource.data.role == resource.data.role && 
                       request.resource.data.isPremium == resource.data.isPremium);
      allow delete: if isAdmin();
    }

    match /current_affairs/{caId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidCurrentAffairs(request.resource.data);
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /llms/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pricing/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
